# ══════════════════════════════════════════════════════════════════════════════
# IGNORE EVERYTHING BY DEFAULT
# ══════════════════════════════════════════════════════════════════════════════
**

# ══════════════════════════════════════════════════════════════════════════════
# WHITELIST: Root files required by VS Code
# ══════════════════════════════════════════════════════════════════════════════
!package.json
!README.md
!LICENSE.txt
!icon.png
!icon.svg

# ══════════════════════════════════════════════════════════════════════════════
# WHITELIST: Extension entry point and bootstrap
# ══════════════════════════════════════════════════════════════════════════════
!bootstrap.js
!tsconfig.base.json

# ══════════════════════════════════════════════════════════════════════════════
# WHITELIST: Compiled extension bundle (only .js files, no maps)
# ══════════════════════════════════════════════════════════════════════════════
!dist/*.js

# ══════════════════════════════════════════════════════════════════════════════
# WHITELIST: Client Controller (MCP server for browser automation)
# ══════════════════════════════════════════════════════════════════════════════
!client-controller/build/index.js
!client-controller/scripts/init.mjs
!client-controller/package.json

# ══════════════════════════════════════════════════════════════════════════════
# WHITELIST: Inspector Panel (webview assets, no maps)
# ══════════════════════════════════════════════════════════════════════════════
!inspector/dist/*.js
!inspector/dist/*.css
!inspector/dist/*.ttf
!inspector/styles.css

# ══════════════════════════════════════════════════════════════════════════════
# WHITELIST: MCP Server (only .js files, no maps)
# ══════════════════════════════════════════════════════════════════════════════
!mcp-server/build/**/*.js

# ══════════════════════════════════════════════════════════════════════════════
# WHITELIST: Runtime dependencies (esbuild externals)
# NOTE: We need specific patterns to avoid pulling in .map and test files
# ══════════════════════════════════════════════════════════════════════════════

# jsonc-parser (leaf — no dependencies)
!node_modules/jsonc-parser/lib/**/*.js
!node_modules/jsonc-parser/package.json