{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2022",
		"lib": ["ES2022"],
		"outDir": "dist",
		"rootDir": ".",
		"resolveJsonModule": true,
		"declaration": false,
		"sourceMap": true
	},
	"include": ["**/*.ts"],
	"exclude": [
		"node_modules",
		"dist",
		"client-controller",
		"inspector",
		"tests",
		"resources",
		"test-workspace",
		"packages/*/tests"
	]
}
