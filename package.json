{
	"name": "vscode-devtools",
	"displayName": "DevTools",
	"version": "0.1.0",
	"description": "VS Code DevTools with Git workspace picker, LM tool management, and MCP integration",
	"categories": [
		"Other"
	],
	"keywords": [
		"api",
		"devtools",
		"mcp",
		"automation"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/AndyLiner13/vscode-devtools.git"
	},
	"license": "Apache-2.0",
	"publisher": "AndyLiner",
	"main": "./dist/extension.js",
	"workspaces": [
		"packages/*",
		"client-controller",
		"inspector"
	],
	"scripts": {
		"build": "vsce package --allow-star-activation --skip-license",
		"check-types": "tsc --noEmit",
		"compile": "node esbuild.mjs",
		"format": "eslint --cache --fix . && prettier --write --cache .",
		"inspector:build": "cd inspector && npm run inspector:build",
		"knip": "knip --strict",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"mcp:build": "cd client-controller && npm run build && tsc --noEmit",
		"mcp:inspect": "node client-controller/scripts/inspect.mjs",
		"reinstall": "npm run build && code.cmd --install-extension vscode-devtools-0.1.0.vsix --force",
		"vscode:prepublish": "node esbuild.mjs --production && cd inspector && node esbuild.mjs --production"
	},
	"contributes": {
		"commands": [
			{
				"command": "devtools.toggleMcpServer",
				"title": "DevTools: Toggle MCP Server",
				"when": "devtools.isHost && config.devtools.dev.enabled"
			},
			{
				"command": "devtools.openInspector",
				"title": "DevTools: Open MCP Inspector",
				"when": "devtools.isHost && config.devtools.dev.enabled"
			},
			{
				"command": "devtools.refreshInspector",
				"title": "DevTools: Refresh MCP Inspector",
				"when": "devtools.isHost && config.devtools.dev.enabled"
			},
			{
				"command": "devtools.startMcpServer",
				"title": "DevTools: Start MCP Server",
				"when": "devtools.isHost && config.devtools.dev.enabled"
			},
			{
				"command": "devtools.stopMcpServer",
				"title": "DevTools: Stop MCP Server",
				"when": "devtools.isHost && config.devtools.dev.enabled"
			},
			{
				"command": "devtools.restartMcpServer",
				"title": "DevTools: Restart MCP Server",
				"when": "devtools.isHost && config.devtools.dev.enabled"
			},
			{
				"command": "devtools.restartTsServer",
				"title": "DevTools: Restart TypeScript Server"
			}
		],
		"keybindings": [
			{
				"command": "devtools.refreshInspector",
				"key": "ctrl+r",
				"mac": "cmd+r",
				"when": "activeWebviewPanelId == 'mcpInspector'"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "devtools.toggleMcpServer",
					"when": "devtools.isHost && config.devtools.dev.enabled"
				},
				{
					"command": "devtools.openInspector",
					"when": "devtools.isHost && config.devtools.dev.enabled"
				},
				{
					"command": "devtools.refreshInspector",
					"when": "devtools.isHost && config.devtools.dev.enabled"
				},
				{
					"command": "devtools.startMcpServer",
					"when": "devtools.isHost && config.devtools.dev.enabled"
				},
				{
					"command": "devtools.stopMcpServer",
					"when": "devtools.isHost && config.devtools.dev.enabled"
				},
				{
					"command": "devtools.restartMcpServer",
					"when": "devtools.isHost && config.devtools.dev.enabled"
				},
				{
					"command": "devtools.restartTsServer",
					"when": "editorLangId =~ /typescript|javascript/"
				}
			]
		},
		"configuration": [
			{
				"title": "Notifications",
				"properties": {
					"devtools.notifications.duration": {
						"type": "integer",
						"default": 3,
						"minimum": -1,
						"description": "How long completion notifications stay visible (seconds). 0 = suppress all, -1 = show until dismissed, >0 = auto-dismiss after N seconds."
					}
				}
			},
			{
				"title": "Developer",
				"properties": {
					"devtools.dev.enabled": {
						"type": "boolean",
						"default": false,
						"description": "Enable dev mode. When enabled, the MCP server is registered and available to Copilot."
					}
				}
			},
			{
				"title": "General",
				"properties": {
					"devtools.clientWorkspace": {
						"type": "string",
						"default": "",
						"description": "Path to the client workspace folder (absolute, or relative to host workspace root). If empty, uses the host workspace root.",
						"scope": "resource"
					},
					"devtools.extensionPath": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"default": [],
						"description": "Paths to VS Code extension folders to load into the client window (absolute, or relative to host workspace root). Auto-detected when empty.",
						"scope": "resource"
					},
					"devtools.extensionDetection.scanDepth": {
						"type": "integer",
						"default": 3,
						"minimum": 1,
						"maximum": 10,
						"description": "Maximum folder depth to scan when auto-detecting VS Code extension folders.",
						"scope": "resource"
					},
					"devtools.buildScriptName": {
						"type": "string",
						"default": "build",
						"description": "The package.json script name to run when building extensions for hot-reload.",
						"scope": "resource"
					},
					"devtools.hotReload.enabled": {
						"type": "boolean",
						"default": true,
						"description": "Enable automatic hot-reload on source changes."
					}
				}
			},
			{
				"title": "Client Window",
				"properties": {
					"devtools.launch.skipReleaseNotes": {
						"type": "boolean",
						"default": true,
						"description": "Suppress the release-notes tab on client startup."
					},
					"devtools.launch.skipWelcome": {
						"type": "boolean",
						"default": true,
						"description": "Suppress the welcome tab on client startup."
					},
					"devtools.launch.disableGpu": {
						"type": "boolean",
						"default": false,
						"description": "Disable GPU hardware acceleration for the client window."
					},
					"devtools.launch.disableWorkspaceTrust": {
						"type": "boolean",
						"default": false,
						"description": "Disable workspace-trust dialog in the client window."
					},
					"devtools.launch.verbose": {
						"type": "boolean",
						"default": false,
						"description": "Enable verbose VS Code logging for the client window."
					},
					"devtools.launch.extraArgs": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"default": [],
						"description": "Arbitrary extra CLI flags forwarded verbatim to the client VS Code."
					}
				}
			},
			{
				"title": "Timeouts",
				"properties": {
					"devtools.hotReload.mcpStatusTimeout": {
						"type": "number",
						"default": 60000,
						"description": "Max wait time (ms) for MCP status tool before timeout."
					}
				}
			},
			{
				"title": "Inspector",
				"properties": {
					"devtools.inspector.autoRetryOnRestart": {
						"type": "boolean",
						"default": false,
						"description": "Automatically retry tool requests after MCP server restarts instead of showing the reboot message."
					}
				}
			}
		],
		"languages": [
			{
				"id": "ignore",
				"filenames": [
					".devtoolsignore"
				]
			}
		],
		"mcpServerDefinitionProviders": [
			{
				"id": "devtools.client-controller",
				"label": "Client Controller"
			}
		]
	},
	"activationEvents": [
		"*"
	],
	"dependencies": {
		"@types/ws": "^8.18.1",
		"@vscode/codicons": "^0.0.44",
		"apache-arrow": "^18.1.0",
		"jsonc-parser": "^3.3.1",
		"koffi": "^2.15.1",
		"logpare": "^0.1.0",
		"remark-directive": "^3.0.1",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"remark-parse": "^11.0.0",
		"ts-morph": "^27.0.2",
		"unified": "^11.0.5",
		"ws": "^8.19.0",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@modelcontextprotocol/inspector": "^0.20.0",
		"@stylistic/eslint-plugin": "^5.4.0",
		"@tailwindcss/postcss": "^4.1.0",
		"@types/mdast": "^4.0.4",
		"@types/node": "22.x",
		"@types/vscode": "^1.100.0",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.25.8",
		"eslint": "^10.0.0",
		"eslint-config-prettier": "^10.1.0",
		"eslint-plugin-jsdoc": "^62.0.0",
		"eslint-plugin-no-secrets": "^2.1.0",
		"eslint-plugin-perfectionist": "^4.0.0",
		"eslint-plugin-unicorn": "^56.0.0",
		"globals": "^17.0.0",
		"mdast-util-directive": "^3.1.0",
		"mdast-util-math": "^3.0.0",
		"postcss": "^8.5.0",
		"prettier": "^3.6.2",
		"prettier-plugin-packagejson": "^2.5.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.43.0"
	},
	"engines": {
		"vscode": "^1.100.0"
	},
	"icon": "icon.png"
}
